# Pumpstr node — configuration. Copie en `.env` et ajuste.

# --- Base ----------------------------------------------------------------
DB_PASSWORD=change-me
API_PORT=3000
RELAY_PORT=7777
VIDEO_HTTP_PORT=8080
VIDEO_RTMP_PORT=1935

# --- Identité / Nostr ----------------------------------------------------
# La seed dérive le npub Nostr ET le wallet Arkade (cf. ADR-004).
# NE COMMIT JAMAIS une vraie seed. Vide = le node en génère une au 1er boot.
PUMPSTR_SEED=
# Relays où publier les events NIP-53 (en plus du relay local).
NOSTR_PUBLISH_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net

# --- Money / Arkade (ADR-001) --------------------------------------------
# Endpoint de l'opérateur Arkade auquel se connecter (les wallets sont
# self-custody côté client ; l'opérateur ne fait que coordonner/co-signer).
ARKADE_OPERATOR_URL=
# Gateway LN-in : LND de l'Umbrel qui bridge les tips Lightning externes (SPIKE #1).
LND_HOST=
LND_MACAROON_PATH=
LND_TLS_CERT_PATH=

# --- Lightning Address ---------------------------------------------------
# Domaine servant `pseudo@LN_ADDRESS_DOMAIN` (via Cloudflare Tunnel typiquement).
LN_ADDRESS_DOMAIN=

# --- Revenu (ADR-006) ----------------------------------------------------
# Zap-split par défaut vers la plateforme, en basis points (100 = 1%).
# Mettre 0 pour un node 100% souverain.
PLATFORM_SPLIT_BPS=150
PLATFORM_NPUB=

# --- Vidéo (ADR-005) -----------------------------------------------------
# v0 = cloudflare | souverain = origin-cdn
VIDEO_MODE=cloudflare
CLOUDFLARE_STREAM_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
# Pull-CDN devant l'origine Owncast (mode origin-cdn) :
CDN_PULL_ZONE_URL=
