# Pumpstr node — config. Copie en .env (ou passe les vars via docker-compose).
PORT=4242
# La clé du node = npub + wallet Arkade. Vide -> fichier .creator-key local.
# En conteneur : montée sur un volume (cf. docker-compose.yml -> /data/.creator-key).
KEY_FILE=

# --- Rail Arkade ---
ARK_SERVER_URL=https://mutinynet.arkade.sh   # mainnet : https://arkade.computer
BOLTZ_NETWORK=mutinynet                        # bitcoin | mutinynet | regtest

# --- Nostr ---
NOSTR_RELAYS=                                  # vide -> défauts (damus, nos.lol, primal)

# --- Live NIP-53 (kind:30311) ---
STREAM_TITLE=
STREAM_SUMMARY=
STREAM_URL=                                    # URL HLS ; vide -> /watch utilise un flux démo
STREAM_IMAGE=

# --- Vidéo : Cloudflare Stream (optionnel) ---
CLOUDFLARE_STREAM_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_CUSTOMER_CODE=               # sous-domaine customer-<CODE> pour l'URL de lecture
